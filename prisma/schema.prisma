generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum POStatus {
  pending
  approved
  rejected
  edit_required
}

model PurchaseOrder {
  id            String    @id @default(cuid())
  poid          String    @unique
  date_created  DateTime  @default(now())
  status        POStatus  @default(pending)
  total_revenue Float     @default(0)
  raw_file_url  String?
  comments      String?
  items         POItem[]

  @@map("purchase_orders")
}

model POItem {
  id            String        @id @default(cuid())
  po_id         String
  sku_name      String
  units_ordered Int
  purchaseOrder PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Cascade)

  @@map("po_items")
}

model Inventory {
  id             String @id @default(cuid())
  sku_name       String @unique
  stock_level    Int    @default(0)
  lead_time_days Int    @default(0)

  @@map("inventory")
}
